generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MAHASISWA
  LABORAN
  KEPALA_LAB
}

enum Kondisi {
  BAIK
  RUSAK
}

enum StatusPinjaman {
  PENDING
  DIPINJAM
  SELESAI
  DITOLAK
}

enum NamaRuangan {
  LAB_RPL
  LAB_JARKOM
  LAB_MM
  LAB_SI
}

enum StatusBooking {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

model User {
  id           String        @id @default(cuid())
  nama         String
  email        String        @unique
  password     String
  role         Role          @default(MAHASISWA)
  borrowings   Borrowing[]
  roomBookings RoomBooking[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AssetCategory {
  id          String      @id @default(cuid())
  nama        String      @unique
  deskripsi   String?
  prefix      String      @unique
  items       AssetItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model AssetItem {
  id          String         @id @default(cuid())
  categoryId  String
  nomorUrut   String         // Contoh: "012"
  kondisi     Kondisi        @default(BAIK)
  isAvailable Boolean        @default(true)
  category    AssetCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  borrowings  Borrowing[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([categoryId, nomorUrut])
}

model Borrowing {
  id           String         @id @default(cuid())
  userId       String
  assetItemId  String
  tglPinjam    DateTime       @default(now())
  returnedDate DateTime?
  status       StatusPinjaman @default(PENDING)
  user         User           @relation(fields: [userId], references: [id])
  assetItem    AssetItem      @relation(fields: [assetItemId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([assetItemId])
  @@index([status])
}

model RoomBooking {
  id          String        @id @default(uuid())
  userId      String
  roomName    NamaRuangan
  bookingDate DateTime
  startTime   String
  endTime     String
  status      StatusBooking @default(PENDING)
  user        User          @relation(fields: [userId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([roomName])
  @@index([status])
  @@index([bookingDate])
}
